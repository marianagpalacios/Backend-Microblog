<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>{{titulo}}</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header class="topo">
        <div>
            <h1>MicroBlog</h1>
            <p>Olá, {{usuario.nome}}!</p>
        </div>
        <nav>
            <a href="/posts">Postagens</a>
            <a href="/users">Usuários</a>
            <a href="/logout">Sair</a>
        </nav>
    </header>

    <main class="container">
        {{#if erro}}
            <p class="mensagem erro">{{erro}}</p>
        {{/if}}

        {{#if sucesso}}
            <p class="mensagem sucesso">{{sucesso}}</p>
        {{/if}}

        <section class="card">
            <h2>Nova postagem</h2>
            <form method="POST" action="/posts/create">
                <label for="conteudo">Conteúdo</label>
                <textarea id="conteudo" name="conteudo" rows="4" placeholder="O que você está pensando?"></textarea>
                <button type="submit">Publicar</button>
            </form>
        </section>

        <section class="card">
            <h2>Buscar postagens</h2>
            <form method="GET" action="/posts" class="linha-form">
                <input type="text" name="busca" value="{{busca}}" placeholder="Buscar por conteúdo">
                <button type="submit">Buscar</button>
                <a class="botao-secundario" href="/posts">Limpar</a>
            </form>
        </section>

        <section class="lista">
            <h2>Postagens</h2>

            {{#each posts}}
                <article class="card post">
                    <div class="meta">
                        <strong>{{autor}}</strong>
                        <span>{{dataFormatada}}</span>
                    </div>

                    <p>{{conteudo}}</p>

                    <div class="acoes">
                        <a class="botao-secundario" href="/posts/{{id}}/comments">Ver comentários</a>

                        {{#if pertenceUsuario}}
                            <form method="POST" action="/posts/delete/{{id}}" class="form-inline">
                                <button type="submit" class="perigo">Excluir</button>
                            </form>
                        {{/if}}
                    </div>
                </article>
            {{/each}}

            {{#unless posts}}
                <p class="vazio">Nenhuma postagem encontrada.</p>
            {{/unless}}
        </section>
    </main>
</body>
</html>
