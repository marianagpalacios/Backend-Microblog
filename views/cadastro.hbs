<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>{{titulo}}</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <main class="container pequeno">
        <section class="card">
            <h1>Criar conta</h1>
            <p class="subtitulo">Preencha os dados para acessar o MicroBlog.</p>

            {{#if erro}}
                <p class="mensagem erro">{{erro}}</p>
            {{/if}}

            <form method="POST" action="/users/create">
                <label for="nome">Nome</label>
                <input type="text" id="nome" name="nome" value="{{nome}}" placeholder="Digite seu nome">

                <label for="email">E-mail</label>
                <input type="email" id="email" name="email" value="{{email}}" placeholder="Digite seu e-mail">

                <label for="senha">Senha</label>
                <input type="password" id="senha" name="senha" placeholder="Digite sua senha">

                <button type="submit">Cadastrar</button>
            </form>

            <p class="link-texto"><a href="/login">Voltar para o login</a></p>
        </section>
    </main>
</body>
</html>
